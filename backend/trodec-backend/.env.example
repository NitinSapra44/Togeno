NODE_ENV=production
PORT=3001

# Supabase — get from supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Razorpay — get from razorpay.com > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Shiprocket — get from app.shiprocket.in > Settings > API
SHIPROCKET_EMAIL=your-shiprocket-email@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://trodec.com,https://www.trodec.com

# SMTP — for order confirmation emails (use Gmail App Password or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Togeno" <noreply@togeno.com>
